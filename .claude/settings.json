{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python \"D:\\AI\\_My_Projects\\manifesto\\hooks\\tool_cap_start.py\""
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"D:\\AI\\_My_Projects\\manifesto\\hooks\\direct_execution_lifecycle.py\""
          },
          {
            "type": "command",
            "command": "python \"D:\\AI\\_My_Projects\\manifesto\\hooks\\tool_cap_enforce.py\""
          },
          {
            "type": "command",
            "command": "python \"D:\\AI\\_My_Projects\\manifesto\\hooks\\context_telemetry.py\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python \"D:\\AI\\_My_Projects\\manifesto\\hooks\\block_agent_commit.py\""
          },
          {
            "type": "command",
            "command": "python \"D:\\AI\\_My_Projects\\manifesto\\hooks\\bash_command_lint.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python \"D:\\AI\\_My_Projects\\manifesto\\hooks\\context_telemetry.py\" --finalize"
          },
          {
            "type": "command",
            "command": "python \"D:\\AI\\_My_Projects\\manifesto\\hooks\\tool_cap_end.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"D:\\AI\\_My_Projects\\manifesto\\hooks\\notify_on_stop.py\""
          },
          {
            "type": "command",
            "command": "python \"D:\\AI\\_My_Projects\\manifesto\\hooks\\post_commit_next_step.py\""
          },
          {
            "type": "command",
            "command": "python \"D:\\AI\\_My_Projects\\manifesto\\hooks\\generate_domain_map.py\""
          },
          {
            "type": "command",
            "command": "python \"D:\\AI\\_My_Projects\\manifesto\\hooks\\auto_verify.py\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "WebFetch",
      "WebSearch",
      "mcp__"
    ],
    "deny": []
  }
}

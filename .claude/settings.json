{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python hooks/tool_cap_enforce.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python hooks/tool_cap_end.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python hooks/post_commit_next_step.py"
          },
          {
            "type": "command",
            "command": "python hooks/generate_domain_map.py"
          }
        ]
      }
    ]
  }
}

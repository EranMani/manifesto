{
  "initialized": true,
  "universal_allowed": [
    "DECISIONS.md",
    "ARCHITECTURE.md",
    "GLOSSARY.md",
    "AGENTS.md",
    "commit-protocol.md",
    "project-state.json",
    ".gitignore",
    "README.md"
  ],
  "agents": {
    "rex@manifesto.local": {
      "name": "Rex",
      "role": "backend",
      "domains": [
        "backend/app/",
        "backend/alembic/",
        "backend/seed.py",
        "backend/pyproject.toml",
        "backend/alembic.ini"
      ]
    },
    "adam@manifesto.local": {
      "name": "Adam",
      "role": "devops",
      "domains": [
        "docker-compose.yml",
        "docker-compose.prod.yml",
        ".env.example",
        "backend/Dockerfile",
        "scripts/",
        "SMOKE_TEST_RESULTS.md"
      ]
    },
    "aria@manifesto.local": {
      "name": "Aria",
      "role": "frontend",
      "domains": [
        "frontend/src/",
        "frontend/package.json",
        "frontend/vite.config.ts",
        "frontend/tailwind.config.ts",
        "frontend/tsconfig.json",
        "frontend/index.html",
        "frontend/postcss.config.js",
        "frontend/.env.example"
      ]
    }
  }
}
